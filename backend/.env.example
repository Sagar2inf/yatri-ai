# ─────────────────────────────────────────────────────────────────────────────
# YatraAI Backend — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Redis (used for session storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
SESSION_TTL_HOURS=24

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: "groq" | "gemini" | "ollama"
# Recommendation: start with "groq" (free, fast, no setup)
LLM_PROVIDER=groq

# ─── Option 1: Groq (Recommended — free, fast, no credit card) ───────────────
# 1. Go to https://console.groq.com
# 2. Sign up / log in
# 3. Click "API Keys" → "Create API Key"
# 4. Paste the key below (starts with gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ─── Option 2: Google Gemini (free tier: 15 req/min, 1500 req/day) ───────────
# 1. Go to https://aistudio.google.com/app/apikey
#    ⚠️  Use aistudio.google.com — NOT console.cloud.google.com
#    ⚠️  Key must start with "AIzaSy" — other Google credentials won't work
# 2. Sign in with a personal Google account
# 3. Click "Create API Key"
# 4. Paste the key below and set LLM_PROVIDER=gemini above
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Option 3: Ollama (100% local, no API key, runs on your machine) ─────────
# 1. Install Ollama: https://ollama.ai/download
# 2. Run: ollama serve
# 3. Pull a model: ollama pull llama3.2:3b
# 4. Set LLM_PROVIDER=ollama above
# Note: Needs at least 8 GB RAM. Quality lower than cloud providers.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=300000
OLLAMA_TEMPERATURE=0.7

# ─── CORS ────────────────────────────────────────────────────────────────────
# Frontend URL — change this if you deploy the frontend elsewhere
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=50
